#!/usr/bin/env python3
"""Borderless markdown viewer with inline image support using GTK WebKit."""

import sys
import os
import markdown
import gi
gi.require_version("Gtk", "3.0")
gi.require_version("WebKit2", "4.1")
from gi.repository import Gtk, WebKit2, Gdk

HTML_TEMPLATE = """<!DOCTYPE html>
<html>
<head>
<style>
body {{
    background: #000000;
    color: #e0e0e0;
    font-family: monospace;
    font-size: 14px;
    padding: 20px;
    margin: 0;
    line-height: 1.6;
}}
h1, h2, h3, h4, h5, h6 {{
    color: #ffffff;
    margin-top: 1em;
    margin-bottom: 0.5em;
}}
h1 {{ font-size: 1.6em; }}
h2 {{ font-size: 1.4em; }}
h3 {{ font-size: 1.2em; }}
code {{
    background: #2a2a2a;
    padding: 2px 6px;
    border-radius: 3px;
    font-size: 0.95em;
}}
pre {{
    background: #2a2a2a;
    padding: 12px;
    border-radius: 6px;
    overflow-x: auto;
}}
pre code {{
    background: none;
    padding: 0;
}}
a {{ color: #6aafff; }}
blockquote {{
    border-left: 3px solid #555;
    margin-left: 0;
    padding-left: 16px;
    color: #aaa;
}}
img {{
    max-width: {max_w}px;
    max-height: {max_h}px;
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: 6px;
    margin: 8px 0;
}}
ul, ol {{ padding-left: 24px; }}
hr {{ border: none; border-top: 1px solid #444; }}
table {{ border-collapse: collapse; width: 100%; }}
th, td {{ border: 1px solid #444; padding: 6px 10px; text-align: left; }}
th {{ background: #2a2a2a; }}
</style>
</head>
<body>{content}</body>
</html>"""


class RenderApp(Gtk.Application):
    def __init__(self, filepath):
        super().__init__(application_id="com.github.render-md")
        self.filepath = filepath

    def do_activate(self):
        with open(self.filepath) as f:
            md_text = f.read()

        html_content = markdown.markdown(md_text, extensions=["fenced_code", "tables"])

        # Count images and scale max size accordingly
        img_count = html_content.count("<img ")
        if img_count <= 1:
            max_w, max_h = 1280, 800
        elif img_count <= 4:
            max_w, max_h = 640, 400
        else:
            max_w, max_h = 420, 260

        html = HTML_TEMPLATE.format(content=html_content, max_w=max_w, max_h=max_h)
        base_uri = "file://" + os.path.dirname(os.path.abspath(self.filepath)) + "/"

        win = Gtk.ApplicationWindow(application=self, title="render-md")
        win.set_default_size(932, 666)
        win.set_decorated(False)
        win.set_resizable(True)

        webview = WebKit2.WebView()
        webview.set_background_color(Gdk.RGBA(0.0, 0.0, 0.0, 1.0))
        webview.load_html(html, base_uri)

        win.add(webview)
        win.connect("key-press-event", lambda w, e: self.quit() if e.keyval in (Gdk.KEY_q, Gdk.KEY_Escape) else None)
        win.show_all()


if __name__ == "__main__":
    if len(sys.argv) < 2:
        print("Usage: render-md <file.md>")
        sys.exit(1)

    filepath = sys.argv[1]
    if not os.path.isfile(filepath):
        print(f"File not found: {filepath}")
        sys.exit(1)

    app = RenderApp(filepath)
    app.run([])

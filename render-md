#!/usr/bin/env python3
"""Borderless markdown viewer with inline image support using GTK WebKit."""

import sys
import os
import markdown
import gi
gi.require_version("Gtk", "3.0")
gi.require_version("WebKit2", "4.1")
from gi.repository import Gtk, WebKit2, Gdk


THEMES = {
    "dark": {
        "bg": "#000000", "fg": "#e0e0e0", "heading": "#ffffff",
        "code_bg": "#2a2a2a", "link": "#6aafff", "quote_border": "#555",
        "quote_fg": "#aaa", "hr": "#444", "table_border": "#444",
        "th_bg": "#2a2a2a",
    },
    "light": {
        "bg": "#ffffff", "fg": "#1a1a1a", "heading": "#000000",
        "code_bg": "#f0f0f0", "link": "#0066cc", "quote_border": "#ccc",
        "quote_fg": "#555", "hr": "#ddd", "table_border": "#ccc",
        "th_bg": "#f0f0f0",
    },
}

HTML_TEMPLATE = """<!DOCTYPE html>
<html>
<head>
<style>
body {{
    background: {bg};
    color: {fg};
    font-family: monospace;
    font-size: 14px;
    padding: 20px;
    margin: 0;
    line-height: 1.6;
}}
h1, h2, h3, h4, h5, h6 {{
    color: {heading};
    margin-top: 1em;
    margin-bottom: 0.5em;
}}
h1 {{ font-size: 1.6em; }}
h2 {{ font-size: 1.4em; }}
h3 {{ font-size: 1.2em; }}
code {{
    background: {code_bg};
    padding: 2px 6px;
    border-radius: 3px;
    font-size: 0.95em;
}}
pre {{
    background: {code_bg};
    padding: 12px;
    border-radius: 6px;
    overflow-x: auto;
}}
pre code {{
    background: none;
    padding: 0;
}}
a {{ color: {link}; }}
blockquote {{
    border-left: 3px solid {quote_border};
    margin-left: 0;
    padding-left: 16px;
    color: {quote_fg};
}}
img {{
    max-width: {max_w};
    max-height: {max_h};
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: 6px;
    margin: 8px 0;
}}
ul, ol {{ padding-left: 24px; }}
hr {{ border: none; border-top: 1px solid {hr}; }}
table {{ border-collapse: collapse; width: 100%; }}
th, td {{ border: 1px solid {table_border}; padding: 6px 10px; text-align: left; }}
th {{ background: {th_bg}; }}
</style>
</head>
<body>{content}</body>
</html>"""


def get_screen_size():
    """Get the primary monitor's logical resolution (CSS pixels)."""
    display = Gdk.Display.get_default()
    if display:
        monitor = display.get_primary_monitor() or display.get_monitor(0)
        if monitor:
            geom = monitor.get_geometry()
            return geom.width, geom.height
    return 1920, 1080


class RenderApp(Gtk.Application):
    def __init__(self, md_text, base_uri="file:///tmp/", no_scale=False, theme="dark"):
        super().__init__(application_id="com.github.render-md")
        self.md_text = md_text
        self.base_uri = base_uri
        self.no_scale = no_scale
        self.theme = theme

    def do_activate(self):
        html_content = markdown.markdown(self.md_text, extensions=["fenced_code", "tables"])

        if self.no_scale:
            max_w, max_h = "none", "none"
        else:
            screen_w, screen_h = get_screen_size()
            img_count = html_content.count("<img ")
            if img_count <= 1:
                max_w = f"{int(screen_w * 0.65)}px"
                max_h = f"{int(screen_h * 0.7)}px"
            elif img_count <= 4:
                max_w = f"{int(screen_w * 0.35)}px"
                max_h = f"{int(screen_h * 0.35)}px"
            else:
                max_w = f"{int(screen_w * 0.22)}px"
                max_h = f"{int(screen_h * 0.22)}px"

        colors = THEMES[self.theme]
        html = HTML_TEMPLATE.format(content=html_content, max_w=max_w, max_h=max_h, **colors)

        bg = colors["bg"]
        r, g, b = int(bg[1:3], 16) / 255, int(bg[3:5], 16) / 255, int(bg[5:7], 16) / 255

        win = Gtk.ApplicationWindow(application=self, title="render-md")
        win.set_default_size(1025, 733)
        win.set_decorated(False)
        win.set_resizable(True)

        webview = WebKit2.WebView()
        webview.set_background_color(Gdk.RGBA(r, g, b, 1.0))
        webview.load_html(html, self.base_uri)

        win.add(webview)
        win.connect("key-press-event", lambda w, e: self.quit() if e.keyval in (Gdk.KEY_q, Gdk.KEY_Escape) else None)
        win.show_all()


if __name__ == "__main__":
    args = sys.argv[1:]
    no_scale = False
    theme = "dark"

    if "--no-scale" in args:
        no_scale = True
        args.remove("--no-scale")

    if "--light" in args:
        theme = "light"
        args.remove("--light")

    if not args and sys.stdin.isatty():
        print("Usage: render-md [--no-scale] [--light] [<file.md>]")
        print("       echo '# Hello' | render-md")
        sys.exit(1)

    if args:
        filepath = args[0]
        if not os.path.isfile(filepath):
            print(f"File not found: {filepath}")
            sys.exit(1)
        with open(filepath) as f:
            md_text = f.read()
        base_uri = "file://" + os.path.dirname(os.path.abspath(filepath)) + "/"
    else:
        md_text = sys.stdin.read()
        base_uri = "file://" + os.getcwd() + "/"

    app = RenderApp(md_text, base_uri=base_uri, no_scale=no_scale, theme=theme)
    app.run([])

#!/usr/bin/env python3
"""Borderless markdown viewer with inline image support.

On Linux: uses GTK WebKit for a native borderless window.
On other platforms: opens in the default browser via a local HTTP server.
"""

import sys
import os
import platform
import markdown

THEMES = {
    "dark": {
        "bg": "#000000", "fg": "#e0e0e0", "heading": "#ffffff",
        "code_bg": "#2a2a2a", "link": "#6aafff", "quote_border": "#555",
        "quote_fg": "#aaa", "hr": "#444", "table_border": "#444",
        "th_bg": "#2a2a2a",
    },
    "light": {
        "bg": "#ffffff", "fg": "#1a1a1a", "heading": "#000000",
        "code_bg": "#f0f0f0", "link": "#0066cc", "quote_border": "#ccc",
        "quote_fg": "#555", "hr": "#ddd", "table_border": "#ccc",
        "th_bg": "#f0f0f0",
    },
}

HTML_TEMPLATE = """<!DOCTYPE html>
<html>
<head>
<style>
body {{
    background: {bg};
    color: {fg};
    font-family: monospace;
    font-size: 14px;
    padding: 20px;
    margin: 0;
    line-height: 1.6;
}}
h1, h2, h3, h4, h5, h6 {{
    color: {heading};
    margin-top: 1em;
    margin-bottom: 0.5em;
}}
h1 {{ font-size: 1.6em; }}
h2 {{ font-size: 1.4em; }}
h3 {{ font-size: 1.2em; }}
code {{
    background: {code_bg};
    padding: 2px 6px;
    border-radius: 3px;
    font-size: 0.95em;
}}
pre {{
    background: {code_bg};
    padding: 12px;
    border-radius: 6px;
    overflow-x: auto;
}}
pre code {{
    background: none;
    padding: 0;
}}
a {{ color: {link}; }}
blockquote {{
    border-left: 3px solid {quote_border};
    margin-left: 0;
    padding-left: 16px;
    color: {quote_fg};
}}
img {{
    max-width: {max_w};
    max-height: {max_h};
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: 6px;
    margin: 8px 0;
}}
ul, ol {{ padding-left: 24px; }}
hr {{ border: none; border-top: 1px solid {hr}; }}
table {{ border-collapse: collapse; width: 100%; }}
th, td {{ border: 1px solid {table_border}; padding: 6px 10px; text-align: left; }}
th {{ background: {th_bg}; }}
</style>
</head>
<body>{content}</body>
</html>"""


def build_html(md_text, theme="dark", no_scale=False, screen_w=1920, screen_h=1080):
    """Convert markdown to themed HTML."""
    html_content = markdown.markdown(md_text, extensions=["fenced_code", "tables"])

    if no_scale:
        max_w, max_h = "none", "none"
    else:
        img_count = html_content.count("<img ")
        if img_count <= 1:
            max_w = f"{int(screen_w * 0.45)}px"
            max_h = f"{int(screen_h * 0.5)}px"
        elif img_count <= 4:
            max_w = f"{int(screen_w * 0.25)}px"
            max_h = f"{int(screen_h * 0.25)}px"
        else:
            max_w = f"{int(screen_w * 0.15)}px"
            max_h = f"{int(screen_h * 0.15)}px"

    colors = THEMES[theme]
    return HTML_TEMPLATE.format(content=html_content, max_w=max_w, max_h=max_h, **colors)


# --- Linux: GTK WebKit backend ---

def run_gtk(md_text, base_uri, no_scale, theme):
    import gi
    gi.require_version("Gtk", "3.0")
    gi.require_version("WebKit2", "4.1")
    from gi.repository import Gtk, WebKit2, Gdk

    def get_screen_size():
        display = Gdk.Display.get_default()
        if display:
            monitor = display.get_primary_monitor() or display.get_monitor(0)
            if monitor:
                geom = monitor.get_geometry()
                return geom.width, geom.height
        return 1920, 1080

    class RenderApp(Gtk.Application):
        def __init__(self):
            super().__init__(application_id="com.github.render-md")

        def do_activate(self):
            screen_w, screen_h = get_screen_size()
            html = build_html(md_text, theme, no_scale, screen_w, screen_h)

            colors = THEMES[theme]
            bg = colors["bg"]
            r, g, b = int(bg[1:3], 16) / 255, int(bg[3:5], 16) / 255, int(bg[5:7], 16) / 255

            win_w = min(1025, int(screen_w * 0.75))
            win_h = min(733, int(screen_h * 0.75))

            win = Gtk.ApplicationWindow(application=self, title="render-md")
            win.set_default_size(win_w, win_h)
            win.set_decorated(False)
            win.set_resizable(True)

            webview = WebKit2.WebView()
            webview.set_background_color(Gdk.RGBA(r, g, b, 1.0))
            webview.load_html(html, base_uri)

            win.add(webview)
            win.connect("key-press-event", lambda w, e: self.quit() if e.keyval in (Gdk.KEY_q, Gdk.KEY_Escape) else None)
            win.show_all()

    app = RenderApp()
    app.run([])


# --- Non-Linux: browser backend ---

def run_browser(md_text, base_uri, no_scale, theme):
    import http.server
    import threading
    import webbrowser

    html = build_html(md_text, theme, no_scale)

    class Handler(http.server.BaseHTTPRequestHandler):
        def do_GET(self):
            if self.path == "/" or self.path == "/index.html":
                self.send_response(200)
                self.send_header("Content-Type", "text/html; charset=utf-8")
                self.end_headers()
                self.wfile.write(html.encode())
            else:
                # Serve local files for images
                filepath = os.path.join(base_uri.replace("file://", ""), self.path.lstrip("/"))
                if os.path.isfile(filepath):
                    self.send_response(200)
                    self.end_headers()
                    with open(filepath, "rb") as f:
                        self.wfile.write(f.read())
                else:
                    self.send_response(404)
                    self.end_headers()

        def log_message(self, format, *args):
            pass

    server = http.server.HTTPServer(("127.0.0.1", 0), Handler)
    port = server.server_address[1]

    thread = threading.Thread(target=server.serve_forever, daemon=True)
    thread.start()

    webbrowser.open(f"http://127.0.0.1:{port}")

    print(f"Serving at http://127.0.0.1:{port} — press Ctrl+C to stop")
    try:
        thread.join()
    except KeyboardInterrupt:
        server.shutdown()


if __name__ == "__main__":
    args = sys.argv[1:]
    no_scale = False
    theme = "dark"

    if "--no-scale" in args:
        no_scale = True
        args.remove("--no-scale")

    if "--light" in args:
        theme = "light"
        args.remove("--light")

    if not args and sys.stdin.isatty():
        print("Usage: render-md [--no-scale] [--light] [<file.md>]")
        print("       echo '# Hello' | render-md")
        sys.exit(1)

    if args:
        filepath = args[0]
        if not os.path.isfile(filepath):
            print(f"File not found: {filepath}")
            sys.exit(1)
        with open(filepath) as f:
            md_text = f.read()
        base_uri = "file://" + os.path.dirname(os.path.abspath(filepath)) + "/"
    else:
        md_text = sys.stdin.read()
        base_uri = "file://" + os.getcwd() + "/"

    if platform.system() == "Linux":
        run_gtk(md_text, base_uri, no_scale, theme)
    else:
        run_browser(md_text, base_uri, no_scale, theme)
